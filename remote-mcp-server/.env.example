# Transport: "stdio" for Claude Code, "streamable-http" for Railway
TRANSPORT=streamable-http

# Railway sets this automatically
PORT=3000

# PostgreSQL (Railway addon provides this)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# NEAR Testnet
NEAR_NETWORK_ID=testnet
NEAR_NODE_URL=https://test.rpc.fastnear.com
DTP_CONTRACT_ID=dtp.direct-trade-protocol.testnet
DTP_MASTER_ACCOUNT=direct-trade-protocol.testnet
DTP_MASTER_PRIVATE_KEY=ed25519:...

# Shippo (test mode key)
SHIPPO_API_KEY=shippo_test_...

# Security
JWT_SECRET=your-jwt-secret-here
KEY_ENCRYPTION_KEY=32-byte-hex-key-for-aes256

# Object storage for KYB docs
S3_BUCKET=dtp-kyb-docs
S3_ENDPOINT=https://...

# Email notifications
SMTP_URL=smtp://...

# Public URL (for OAuth callbacks)
PUBLIC_URL=https://dtp-mcp.up.railway.app
